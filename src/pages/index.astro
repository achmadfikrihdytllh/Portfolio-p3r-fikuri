---
import MainLayout from '../layouts/MainLayout.astro';
import Skills from '../components/Skills.astro';
import Resume from '../components/Resume.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import SummonIntro from '../components/SummonIntro.astro';
import Calendar from '../components/Calendar.astro'; 
import AigisChat from '../components/AigisChat.astro';
---

<MainLayout title="Portfolio | Fikuri Olenyeva">
    
    <SummonIntro />
    
    <Calendar />
    
    <main class="min-h-screen flex items-center justify-center p-4 relative z-20 overflow-hidden">
        
        <div class="relative w-full max-w-6xl">
            <div id="hero-bg-overlay" class="absolute top-0 right-0 w-4/5 h-full bg-accent/20 -skew-x-12 border-r-4 border-primary/50 z-0 transition-all duration-700"></div>

            <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16 relative z-10 px-4">
                
                <div class="w-56 h-56 md:w-80 md:h-80 shrink-0 relative group z-50">
                    <div id="profile-border" class="absolute inset-0 border-2 border-primary -skew-x-6 transform group-hover:skew-x-0 transition-all duration-500 shadow-[0_0_25px_var(--persona-shadow)]"></div>
                    <div class="absolute inset-0 bg-accent/80 -skew-x-6 translate-x-3 translate-y-3 -z-10 transition-colors"></div>

                    <div id="phantom-logo-wrap" class="absolute left-0 top-0 -translate-x-[40%] -translate-y-[54%] z-[70] w-52 md:w-72 pointer-events-none opacity-0 transition-opacity duration-300">
                        <video
                            id="phantom-logo-video"
                            class="absolute inset-0 w-full h-full opacity-0 pointer-events-none"
                            muted
                            loop
                            playsinline
                            preload="auto"
                        ></video>
                        <canvas id="phantom-logo-canvas" class="w-full h-full drop-shadow-[0_0_12px_rgba(255,0,0,0.65)]"></canvas>
                    </div>
                    
                    <img 
                        id="profile-image"
                        src="/profile.png" 
                        alt="Profile" 
                        class="w-full h-full object-cover -skew-x-6 grayscale transition-all duration-1000 shadow-[0_0_15px_rgba(0,0,0,0.5)]" 
                    />

                    <div id="evoker-gun" class="absolute -left-40 top-10 md:-left-64 md:top-12 z-[60] w-52 md:w-[380px] transform -rotate-[15deg] transition-all duration-500 origin-bottom-right">
                        <img src="/evoker.png" alt="Evoker" class="w-full h-full object-contain drop-shadow-[0_0_15px_rgba(255,255,255,0.4)]" />
                    </div>
                </div>

                <div class="flex-1 text-center md:text-left relative z-20">
                    <h2 class="text-lg md:text-2xl font-bold uppercase tracking-widest text-gray-300 -skew-x-12 mb-[-5px]">Fikuri Olenyeva</h2>
                    <h1 class="text-5xl md:text-7xl font-black italic uppercase tracking-tighter -skew-x-12 text-white drop-shadow-[3px_3px_0_#000]">
                        <span id="hero-name" class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-white to-primary transition-all duration-700">
                            Achmad Fikri Hidayatullah
                        </span>
                    </h1>
                    
                    <div id="role-tag" class="mt-6 inline-flex items-center bg-white text-black px-6 py-2 -skew-x-12 border-l-8 border-primary shadow-[0_0_20px_var(--persona-shadow)] transition-all">
                        <span class="text-xl md:text-2xl font-black uppercase tracking-widest skew-x-12 md:skew-x-0">Backend Developer</span>
                    </div>

                    <p id="hero-desc" class="mt-6 text-gray-300 text-base md:text-lg max-w-lg leading-relaxed bg-black/60 p-4 backdrop-blur-sm border-l-2 border-primary/50 shadow-lg font-['Exo_2'] transition-all">
                        Specialized in <span class="text-primary font-bold">AdonisJS</span> & <span class="text-primary font-bold">Laravel</span>. Crafting robust APIs and scalable server-side architectures.
                    </p>
                    
                    <div class="mt-8 flex flex-wrap gap-4 justify-center md:justify-start">
                        <a href="#projects" class="group relative px-8 py-3 bg-transparent border-2 border-primary text-primary font-bold uppercase tracking-widest overflow-hidden hover:text-black transition-colors -skew-x-12">
                            <span class="absolute inset-0 w-full h-full bg-primary transform -translate-x-full skew-x-12 group-hover:translate-x-0 transition-transform duration-300 ease-out"></span>
                            <span class="relative block skew-x-12">View Projects</span>
                        </a>

                        <a href="/timeline" class="group relative px-8 py-3 bg-white/10 backdrop-blur-sm border-2 border-white/50 text-white font-bold uppercase tracking-widest overflow-hidden hover:border-primary hover:text-primary transition-all -skew-x-12">
                            <span class="absolute inset-0 w-full h-full bg-white transform translate-x-full -skew-x-12 group-hover:translate-x-0 transition-transform duration-300 ease-out"></span>
                            <span class="relative block skew-x-12">View Timeline</span>
                        </a>
                    </div>
                </div>
            </div>

            <div id="persona-container" class="absolute right-0 md:-right-80 top-[40%] -translate-y-1/2 w-[400px] md:w-[850px] pointer-events-none z-0 opacity-0 translate-x-20 scale-95 transition-all duration-[2000ms] ease-out hidden lg:block">
                <img id="persona-img" src="/thanatos.png" alt="Persona" class="w-full h-full object-contain filter drop-shadow-[0_0_40px_var(--persona-shadow)] transition-all duration-700" />
            </div>
        </div>
    </main>

    <div class="relative z-10 bg-black/40 backdrop-blur-sm border-y border-primary/20"><Skills /></div>
    <div class="relative z-10 border-b border-accent/30 shadow-[0_0_30px_var(--persona-shadow)]"><Resume /></div>
    <div class="relative z-10"><Projects /></div>
    <div class="relative z-10 border-t border-gray-800"><Contact /></div>

    <footer class="py-10 text-center text-gray-500 font-mono text-sm relative z-10 border-t border-gray-800 bg-black">
        <p id="footer-text"> © 2026 Fikuri Olenyeva || S.E.E.S PROTOCOL </p>
    </footer>

    <AigisChat />

    <script>
        // LOGIKA WORLD SHIFT: Background & Aset
        const updateWorldAssets = (theme: string) => {
            const personaImg = document.getElementById('persona-img') as HTMLImageElement;
            const evoker = document.getElementById('evoker-gun');
            const footerText = document.getElementById('footer-text');
            const calendar = document.getElementById('p3-calendar-root');
            const phantomLogoWrap = document.getElementById('phantom-logo-wrap') as HTMLDivElement | null;

            if (phantomLogoWrap) {
                if (theme === 'p5') {
                    phantomLogoWrap.style.display = 'block';
                    phantomLogoWrap.style.opacity = '1';
                } else {
                    phantomLogoWrap.style.opacity = '0';
                    phantomLogoWrap.style.display = 'none';
                }
            }

            if (theme === 'p5') {
                // Protokol Persona 5
                if (personaImg) personaImg.src = "/Satanael.png";
                if (evoker) evoker.style.display = "none";
                if (calendar) calendar.style.display = "none";
                if (footerText) footerText.innerText = "© 2026 Fikuri Olenyeva || PHANTOM_THIEVES PROTOCOL";
            } else {
                // Protokol Persona 3
                if (personaImg) personaImg.src = "/thanatos.png";
                if (evoker) evoker.style.display = "none";
                if (calendar) calendar.style.display = "block";
                if (footerText) footerText.innerText = "© 2026 Fikuri Olenyeva || S.E.E.S PROTOCOL";
            }
        };

        const currentTheme = document.documentElement.getAttribute('data-theme') || 'p3';
        updateWorldAssets(currentTheme);

        window.addEventListener('worldShift', (e: any) => {
            updateWorldAssets(e.detail.theme);
        });

        const initPhantomLogoOverlay = () => {
            const wrap = document.getElementById('phantom-logo-wrap') as HTMLDivElement | null;
            const video = document.getElementById('phantom-logo-video') as HTMLVideoElement | null;
            const canvas = document.getElementById('phantom-logo-canvas') as HTMLCanvasElement | null;

            if (!wrap || !video || !canvas) return;

            const ctx = canvas.getContext('2d', { willReadFrequently: true });
            if (!ctx) return;

            const candidates = ['/Phantom Thieves.mp4', '/Phantom Thieves Logo.mp4', '/phantom-thieves-logo.mp4'];
            let rafId = 0;
            let ready = false;

            const draw = () => {
                if (!ready || video.paused || video.ended) return;

                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                const frame = ctx.getImageData(0, 0, canvas.width, canvas.height);
                const data = frame.data;

                for (let i = 0; i < data.length; i += 4) {
                    const r = data[i];
                    const g = data[i + 1];
                    const b = data[i + 2];
                    const isGreen = g > 150 && (g - r) > 45 && (g - b) > 45;
                    if (isGreen) data[i + 3] = 0;
                }

                ctx.putImageData(frame, 0, 0);
                rafId = requestAnimationFrame(draw);
            };

            const drawStaticFrame = () => {
                if (!canvas.width || !canvas.height) return;
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                const frame = ctx.getImageData(0, 0, canvas.width, canvas.height);
                const data = frame.data;

                for (let i = 0; i < data.length; i += 4) {
                    const r = data[i];
                    const g = data[i + 1];
                    const b = data[i + 2];
                    const isGreen = g > 150 && (g - r) > 45 && (g - b) > 45;
                    if (isGreen) data[i + 3] = 0;
                }

                ctx.putImageData(frame, 0, 0);
                wrap.style.opacity = '1';
            };

            const startRender = async () => {
                try {
                    await video.play();
                    ready = true;
                    wrap.style.opacity = '1';
                    if (!rafId) rafId = requestAnimationFrame(draw);
                } catch {
                    drawStaticFrame();
                }
            };

            const syncLogoVisibility = () => {
                const theme = document.documentElement.getAttribute('data-theme') || 'p3';

                if (theme !== 'p5') {
                    wrap.style.opacity = '0';
                    wrap.style.display = 'none';
                    cancelAnimationFrame(rafId);
                    rafId = 0;
                    video.pause();
                    return;
                }

                wrap.style.display = 'block';
                wrap.style.opacity = '1';
                if (canvas.width && canvas.height) drawStaticFrame();
                if (!ready) startRender();
            };

            video.addEventListener('loadeddata', () => {
                wrap.style.aspectRatio = `${Math.max(1, video.videoWidth)} / ${Math.max(1, video.videoHeight)}`;
                canvas.width = Math.max(1, video.videoWidth);
                canvas.height = Math.max(1, video.videoHeight);
                drawStaticFrame();
                startRender();
            }, { once: true });

            document.addEventListener('click', () => {
                if (!ready) startRender();
            }, { once: true });

            document.addEventListener('visibilitychange', () => {
                if (document.hidden) {
                    cancelAnimationFrame(rafId);
                    rafId = 0;
                    video.pause();
                    return;
                }

                if (ready) startRender();
            });

            window.addEventListener('worldShift', () => {
                syncLogoVisibility();
            });

            document.addEventListener('personaSummoned', () => {
                syncLogoVisibility();
            });

            const trySource = (idx: number) => {
                if (idx >= candidates.length) {
                    wrap.style.opacity = '1';
                    return;
                }

                const onError = () => {
                    video.removeEventListener('error', onError);
                    trySource(idx + 1);
                };

                video.addEventListener('error', onError, { once: true });
                video.src = candidates[idx];
                video.load();
            };

            trySource(0);
            syncLogoVisibility();
        };

        initPhantomLogoOverlay();

        // Animasi Summoning
        document.addEventListener('personaSummoned', () => {
            const calendar = document.getElementById('p3-calendar-root');
            if (calendar && document.documentElement.getAttribute('data-theme') === 'p3') {
                calendar.classList.remove('opacity-0', 'pointer-events-none');
                calendar.classList.add('opacity-100');
            }

            const gun = document.getElementById('evoker-gun');
            if (gun && document.documentElement.getAttribute('data-theme') === 'p3') {
                gun.style.transform = 'translateX(-50px) rotate(-45deg) scale(0.9)';
                setTimeout(() => {
                    gun.style.opacity = '0';
                    gun.style.transform = 'translateY(200px)';
                }, 200);
            }
            
            const profile = document.getElementById('profile-image');
            if (profile) profile.classList.remove('grayscale');
            
            const persona = document.getElementById('persona-container');
            if (persona) {
                persona.classList.remove('opacity-0', 'translate-x-20', 'scale-95');
                persona.classList.add('opacity-100', 'translate-x-0', 'scale-100');
            }
        });
    </script>
</MainLayout>