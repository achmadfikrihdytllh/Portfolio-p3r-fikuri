---
// src/layouts/MainLayout.astro
import "../styles/global.css";
import Bubbles from '../components/Bubbles.astro'; 
import MusicPlayer from '../components/MusicPlayer.astro';
import Navbar from '../components/Navbar.astro';
import { ViewTransitions } from 'astro:transitions';
import ProjectModal from "../components/ProjectModal.astro";
import AigisChat from '../components/AigisChat.astro'; 

interface Props {
  title: string;
  isVelvetRoom?: boolean;
  hideDefaultMusic?: boolean; 
}

const OWNER_BASE_THEME = 'p3'; 

const { 
    title, 
    isVelvetRoom = false, 
    hideDefaultMusic = false 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ViewTransitions />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,400;0,600;0,700;0,900;1,700&display=swap" rel="stylesheet">

        <script is:inline define:vars={{ OWNER_BASE_THEME }}>
            const initTheme = () => {
                const saved = localStorage.getItem('persona-theme');
                const theme = saved || OWNER_BASE_THEME;
                document.documentElement.setAttribute('data-theme', theme);
            };
            initTheme();
            document.addEventListener('astro:after-swap', initTheme);
        </script>
    </head>
    
    <body 
        data-page-type={isVelvetRoom ? "velvet" : "normal"}
        class="bg-p-bg text-white font-['Exo_2'] overflow-x-hidden relative min-h-screen transition-all duration-[1000ms]"
    >
        <div 
            id="normal-bg" 
            class="fixed inset-0 z-[-10] transition-opacity duration-[2000ms] bg-cover bg-center bg-no-repeat"
            style="background-image: url('/p3rwallpaper.png'); opacity: 0.6;"
        >
            <div class="absolute inset-0 bg-gradient-to-b from-blue-900/20 via-transparent to-black/40"></div>
        </div>
        
        <div id="dark-hour-bg" class="fixed inset-0 z-[-9] opacity-0 transition-opacity duration-[3000ms] bg-cover bg-center bg-no-repeat pointer-events-none" style="background-image: url('/dark-hour.png');">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_20%,rgba(0,0,0,0.8)_100%)]"></div>
        </div>

        <div 
            id="p5-bg" 
            class="fixed inset-0 z-[-8] opacity-0 transition-opacity duration-[2000ms] bg-cover bg-center bg-no-repeat pointer-events-none" 
            style="background-image: url('/shibuya.jpg');"
        >
            <div class="absolute inset-0 bg-black/40"></div>
        </div>

        { !isVelvetRoom && <Navbar /> }
        { !isVelvetRoom && !hideDefaultMusic && <MusicPlayer /> }

        { !isVelvetRoom && (
            <div id="bubbles-wrapper" class="transition-opacity duration-[2000ms]">
                <Bubbles />
            </div>
        )}
        
        <ProjectModal />
        { !isVelvetRoom && <AigisChat /> }

        <div id="base-vignette" class="fixed inset-0 pointer-events-none z-[-1] transition-all duration-1000" style="background: radial-gradient(circle at center, transparent 20%, var(--color-bg) 120%); opacity: 0.6;"></div>

        <div id="top" class="relative z-10">
            <slot />
        </div>

        <script>
            const updateWorldVisuals = () => {
                const hour = new Date().getHours();
                const body = document.body;
                const isVelvet = body.getAttribute('data-page-type') === 'velvet';
                const currentTheme = document.documentElement.getAttribute('data-theme');

                const normalBg = document.getElementById('normal-bg');
                const darkHourBg = document.getElementById('dark-hour-bg');
                const p5Bg = document.getElementById('p5-bg'); // Layer Baru
                const baseVignette = document.getElementById('base-vignette');
                const bubbles = document.getElementById('bubbles-wrapper');

                // Logika Reset Semua
                if (normalBg) normalBg.style.opacity = "0";
                if (darkHourBg) darkHourBg.style.opacity = "0";
                if (p5Bg) p5Bg.style.opacity = "0";
                if (bubbles) bubbles.style.opacity = "0";

                if (isVelvet) {
                    if (baseVignette) baseVignette.style.opacity = "0";
                    return;
                }

                // EKSEKUSI TEMA
                if (currentTheme === 'p5') {
                    // MODE PERSONA 5
                    if (p5Bg) p5Bg.style.opacity = "1";
                    if (baseVignette) baseVignette.style.opacity = "0.7";
                } else {
                    // MODE PERSONA 3
                    const isDarkHour = hour >= 0 && hour < 5;
                    
                    if (isDarkHour) {
                        body.classList.add('dark-hour-active');
                        if (darkHourBg) darkHourBg.style.opacity = "1";
                    } else {
                        body.classList.remove('dark-hour-active');
                        if (normalBg) normalBg.style.opacity = "0.6";
                        if (bubbles) bubbles.style.opacity = "1";
                    }
                    if (baseVignette) baseVignette.style.opacity = "0.5";
                }
            };

            updateWorldVisuals();
            document.addEventListener('DOMContentLoaded', updateWorldVisuals);
            document.addEventListener('astro:after-swap', updateWorldVisuals);
            window.addEventListener('worldShift', updateWorldVisuals);
        </script>
    </body>
</html>