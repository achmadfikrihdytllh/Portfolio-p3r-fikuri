---
// src/components/Navbar.astro
const links = [
  { name: "HOME", href: "#top" },
  { name: "SKILLS", href: "#skills" },
  { name: "RESUME", href: "#resume" },
  { name: "PROJECTS", href: "#projects" },
  { name: "CONTACT", href: "#contact" },
];
---

<nav id="navbar-system" class="fixed top-2 md:top-6 left-2 md:left-6 z-[9000] flex flex-col items-start gap-2 opacity-0 -translate-x-10 transition-all duration-1000 ease-out">
    
    <button id="menu-toggle-btn" class="group relative focus:outline-none p-1 transition-transform duration-300 hover:scale-105 active:scale-95">
        <img 
            src="/aigis-icon.png" 
            alt="System Menu" 
            class="w-20 h-20 md:w-40 md:h-40 object-contain group-hover:rotate-12 transition-all duration-300 drop-shadow-[0_0_15px_var(--color-primary)]"
        />
    </button>

    <div id="menu-dropdown" class="flex flex-col items-start gap-2 pl-2 md:pl-4 overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-out origin-top-left">
        
        {links.map((link, index) => (
            <a href={link.href} class="menu-item group relative block opacity-0 -translate-x-5 transition-all duration-300" style={`transition-delay: ${index * 100}ms`}>
                <div class="bg-black/90 border-l-4 border-primary px-6 py-2 -skew-x-12 hover:bg-primary hover:border-white hover:pl-8 transition-all duration-200 min-w-[180px] shadow-[0_0_15px_rgba(0,0,0,0.8)]">
                    <span class="block skew-x-12 text-sm font-bold text-gray-300 group-hover:text-white tracking-widest uppercase italic">
                        {link.name}
                    </span>
                </div>
            </a>
        ))}

        <div class="menu-item opacity-0 -translate-x-5 transition-all duration-300 mt-4" style={`transition-delay: ${links.length * 100}ms`}>
            <p class="text-[9px] font-black italic text-primary mb-2 tracking-tighter uppercase pl-1">Protocol_Shift_Sequence</p>
            <div class="flex gap-2">
                <button onclick="changeWorld('p5')" class="group/p5 relative w-12 h-12 bg-transparent border-0 -skew-x-12 transition-all active:scale-95 flex items-center justify-center overflow-hidden">
                    <video
                        id="p5-switch-video"
                        src="/Phantom%20Thieves%20Logo.mp4"
                        class="absolute inset-0 w-full h-full opacity-0 pointer-events-none"
                        autoplay
                        muted
                        loop
                        playsinline
                        preload="auto"
                    ></video>
                    <canvas id="p5-switch-canvas" class="w-16 h-16 object-contain skew-x-12 pointer-events-none"></canvas>
                </button>

                <button onclick="changeWorld('p3')" class="group/p3 relative w-12 h-12 bg-black border-2 border-cyan-400 -skew-x-12 hover:bg-cyan-400 transition-all shadow-lg active:scale-95 flex items-center justify-center overflow-hidden">
                    <img
                        src="/p3logo.png"
                        alt="P3 logo"
                        class="w-9 h-9 object-contain skew-x-12 pointer-events-none"
                    />
                </button>
            </div>
        </div>

    </div>
</nav>

<script is:inline>
    // Logic Menu Utama
    const menuBtn = document.getElementById('menu-toggle-btn');
    const dropdown = document.getElementById('menu-dropdown');
    const menuItems = document.querySelectorAll('.menu-item');
    const navbarContainer = document.getElementById('navbar-system');
    
    let isOpen = false;
    let isAnimating = false; 

    function toggleMenu() {
        if (isAnimating) return; 
        isOpen = !isOpen;
        isAnimating = true;

        if (isOpen) {
            dropdown?.classList.remove('max-h-0', 'opacity-0');
            dropdown?.classList.add('max-h-[600px]', 'opacity-100');
            menuItems.forEach((item, idx) => {
                setTimeout(() => item.classList.remove('opacity-0', '-translate-x-5'), idx * 80); 
            });
            setTimeout(() => { isAnimating = false; }, menuItems.length * 80);
        } else {
            menuItems.forEach((item, idx) => {
                const reverseDelay = (menuItems.length - 1 - idx) * 80;
                setTimeout(() => item.classList.add('opacity-0', '-translate-x-5'), reverseDelay);
            });
            setTimeout(() => {
                dropdown?.classList.remove('max-h-[600px]', 'opacity-100');
                dropdown?.classList.add('max-h-0', 'opacity-0');
                isAnimating = false; 
            }, menuItems.length * 80);
        }
    }

    // Logic WORLD SHIFT (Broadcast Signal)
    window.changeWorld = function(world) {
        document.documentElement.setAttribute('data-theme', world);
        localStorage.setItem('persona-theme', world);
        
        // Kirim sinyal ke Aigis, MusicPlayer, dan Hero
        window.dispatchEvent(new CustomEvent('worldShift', { detail: { theme: world } }));
        
        // Berikan feedback visual kecil (Opsional)
        console.log("PROCOTOL_SHIFT: Initializing " + world.toUpperCase() + " environment.");
    }

    menuBtn?.addEventListener('click', toggleMenu);
    menuItems.forEach(link => {
        link.addEventListener('click', (e) => {
            if (e.target.tagName !== 'BUTTON' && isOpen) toggleMenu();
        });
    });

    const initP5SwitcherLogo = () => {
        const video = document.getElementById('p5-switch-video');
        const canvas = document.getElementById('p5-switch-canvas');
        if (!video || !canvas) return;

        const ctx = canvas.getContext('2d', { willReadFrequently: true });
        if (!ctx) return;
        const workCanvas = document.createElement('canvas');
        const workCtx = workCanvas.getContext('2d', { willReadFrequently: true });
        if (!workCtx) return;

        let rafId = 0;
        let ready = false;
        const maxProcessSize = 220;

        const setupCanvasSize = () => {
            const vw = Math.max(1, video.videoWidth);
            const vh = Math.max(1, video.videoHeight);
            const scale = Math.min(1, maxProcessSize / Math.max(vw, vh));
            const w = Math.max(1, Math.round(vw * scale));
            const h = Math.max(1, Math.round(vh * scale));

            workCanvas.width = w;
            workCanvas.height = h;
            canvas.width = w;
            canvas.height = h;
        };

        const removeGreenAndGetBounds = () => {
            workCtx.clearRect(0, 0, workCanvas.width, workCanvas.height);
            workCtx.drawImage(video, 0, 0, workCanvas.width, workCanvas.height);

            const frame = workCtx.getImageData(0, 0, workCanvas.width, workCanvas.height);
            const data = frame.data;
            let minX = workCanvas.width;
            let minY = workCanvas.height;
            let maxX = -1;
            let maxY = -1;

            for (let i = 0; i < data.length; i += 4) {
                const r = data[i];
                const g = data[i + 1];
                const b = data[i + 2];
                const isGreen = g > 150 && (g - r) > 45 && (g - b) > 45;
                if (isGreen) {
                    data[i + 3] = 0;
                    continue;
                }

                if (data[i + 3] > 20) {
                    const px = (i / 4) % workCanvas.width;
                    const py = Math.floor((i / 4) / workCanvas.width);
                    if (px < minX) minX = px;
                    if (py < minY) minY = py;
                    if (px > maxX) maxX = px;
                    if (py > maxY) maxY = py;
                }
            }

            workCtx.putImageData(frame, 0, 0);

            if (maxX < minX || maxY < minY) return null;
            return {
                x: minX,
                y: minY,
                w: Math.max(1, maxX - minX + 1),
                h: Math.max(1, maxY - minY + 1),
            };
        };

        const drawFittedLogo = () => {
            const bounds = removeGreenAndGetBounds();
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (!bounds) return;

            const padding = 0;
            const availW = canvas.width * (1 - padding * 2);
            const availH = canvas.height * (1 - padding * 2);
            const scale = Math.min(availW / bounds.w, availH / bounds.h);
            const destW = bounds.w * scale;
            const destH = bounds.h * scale;
            const destX = (canvas.width - destW) / 2;
            const destY = (canvas.height - destH) / 2;

            ctx.drawImage(workCanvas, bounds.x, bounds.y, bounds.w, bounds.h, destX, destY, destW, destH);
        };

        const draw = () => {
            if (!ready || video.paused || video.ended) return;
            drawFittedLogo();
            rafId = requestAnimationFrame(draw);
        };

        const drawStaticFrame = () => {
            if (!canvas.width || !canvas.height) return;
            drawFittedLogo();
        };

        const start = async () => {
            try {
                await video.play();
                ready = true;
                if (!rafId) rafId = requestAnimationFrame(draw);
            } catch {
                drawStaticFrame();
            }
        };

        video.addEventListener('loadeddata', () => {
            setupCanvasSize();
            drawStaticFrame();
            start();
        }, { once: true });

        document.addEventListener('click', () => {
            if (!ready) start();
        }, { once: true });
    };

    initP5SwitcherLogo();

    document.addEventListener('personaSummoned', () => {
        if (navbarContainer) {
            navbarContainer.classList.remove('opacity-0', '-translate-x-10');
            navbarContainer.classList.add('translate-x-0');
        }
    });
</script>